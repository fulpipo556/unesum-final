        texto.toLowerCase().includes('contenido') ||
        texto.toLowerCase().includes('resultado') ||
        texto.toLowerCase().includes('criterio') ||
        texto.toLowerCase().includes('instrumento') ||
        texto.toLowerCase().includes('evaluación') ||
