        {/* Resultados de la comparación */}
        {comparacion && (
          <>
            <Card>
              <CardHeader>
                <div className="flex items-center justify-between">
                  <CardTitle>Resultados de la Comparación</CardTitle>
                  <Button onClick={exportarComparacion} variant="outline" size="sm">
                    <Download className="mr-2 h-4 w-4" />
                    Exportar
                  </Button>
                </div>
              </CardHeader>
              <CardContent>
                <Tabs defaultValue="ambos">
                  <TabsList className="grid w-full grid-cols-4">
                    <TabsTrigger value="ambos">
                      En Ambos <Badge variant="secondary" className="ml-2">{comparacion.enAmbos.length}</Badge>
                    </TabsTrigger>
                    <TabsTrigger value="syllabus">
                      Solo Syllabus <Badge variant="secondary" className="ml-2">{comparacion.soloEnSyllabus.length}</Badge>
                    </TabsTrigger>
                    <TabsTrigger value="programa">
                      Solo P.A. <Badge variant="secondary" className="ml-2">{comparacion.soloEnProgramaAnalitico.length}</Badge>
                    </TabsTrigger>
                    <TabsTrigger value="similares">
                      Similares <Badge variant="secondary" className="ml-2">{comparacion.similares.length}</Badge>
                    </TabsTrigger>
                  </TabsList>

                  <TabsContent value="ambos" className="space-y-2 mt-4">
                    <Alert className="bg-green-50 border-green-200">
                      <CheckCircle2 className="h-4 w-4 text-green-600" />
                      <AlertDescription className="text-green-800">
                        Títulos presentes en ambos documentos
                      </AlertDescription>
                    </Alert>
                    {comparacion.enAmbos.map((titulo, idx) => (
                      <div key={idx} className="p-3 bg-white border rounded-lg">
                        <div className="flex items-center gap-2">
                          <CheckCircle2 className="h-4 w-4 text-green-600" />
                          <span>{titulo}</span>
                        </div>
                      </div>
                    ))}
                  </TabsContent>

                  <TabsContent value="syllabus" className="space-y-2 mt-4">
                    <Alert className="bg-blue-50 border-blue-200">
                      <FileText className="h-4 w-4 text-blue-600" />
                      <AlertDescription className="text-blue-800">
                        Títulos solo en Syllabus
                      </AlertDescription>
                    </Alert>
                    {comparacion.soloEnSyllabus.map((titulo, idx) => (
                      <div key={idx} className="p-3 bg-white border rounded-lg">
                        <div className="flex items-center gap-2">
                          <XCircle className="h-4 w-4 text-blue-600" />
                          <span>{titulo}</span>
                        </div>
                      </div>
                    ))}
                  </TabsContent>

                  <TabsContent value="programa" className="space-y-2 mt-4">
                    <Alert className="bg-purple-50 border-purple-200">
                      <FileText className="h-4 w-4 text-purple-600" />
                      <AlertDescription className="text-purple-800">
                        Títulos solo en Programa Analítico
                      </AlertDescription>
                    </Alert>
                    {comparacion.soloEnProgramaAnalitico.map((titulo, idx) => (
                      <div key={idx} className="p-3 bg-white border rounded-lg">
                        <div className="flex items-center gap-2">
                          <XCircle className="h-4 w-4 text-purple-600" />
                          <span>{titulo}</span>
                        </div>
                      </div>
                    ))}
                  </TabsContent>

                  <TabsContent value="similares" className="space-y-2 mt-4">
                    <Alert className="bg-yellow-50 border-yellow-200">
                      <AlertCircle className="h-4 w-4 text-yellow-600" />
                      <AlertDescription className="text-yellow-800">
                        Títulos similares pero no idénticos
                      </AlertDescription>
                    </Alert>
                    {comparacion.similares.map((similar, idx) => (
                      <div key={idx} className="p-3 bg-white border rounded-lg">
                        <div className="space-y-2">
                          <div className="flex items-center gap-2">
                            <span className="text-xs text-gray-500">Syllabus:</span>
                            <span className="font-medium">{similar.syllabus}</span>
                          </div>
                          <div className="flex items-center gap-2">
                            <span className="text-xs text-gray-500">P. Analítico:</span>
                            <span className="font-medium">{similar.programaAnalitico}</span>
                          </div>
                          <Badge variant="outline">
                            {(similar.similitud * 100).toFixed(0)}% similar
                          </Badge>
                        </div>
                      </div>
                    ))}
                  </TabsContent>
                </Tabs>
              </CardContent>
            </Card>
          </>
        )}
      </div>
    </div>
  )
}

