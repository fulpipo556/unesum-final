                    </CardHeader>
                    <CardContent className="pt-6 space-y-4">
                      <div className="space-y-2">
                        <Label>Nombre de la Unidad Temática *</Label>
                        <Input
                          value={unidad.unidad_tematica}
                          onChange={(e) =>
                            handleUnidadChange(unidad.id, "unidad_tematica", e.target.value)
