        (texto.length > 5 && texto.length < 100 && /^[A-ZÁÉÍÓÚÑ]/.test(texto))
      );
      
      if (esImportante) {
        const titulo = normalizeTitulo(texto);
        if (titulo && titulo.length > 2 && !titulosSet.has(titulo) && !/^[\d\s\-:]+$/.test(titulo)) {
