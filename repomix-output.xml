            for (let i = 1; i <= 5; i++) {
              if (idx + i < data.length) {
                const filaTest = data[idx + i];
                
                // Contar columnas NO vacÃ­as
                const columnasConTexto = filaTest.filter(cell => {
                  const texto = cell ? cell.toString().trim() : '';
