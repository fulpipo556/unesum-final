    console.log(`✓ Textos únicos extraídos: ${todosLosTextos.size}`);
    
    // Procesar cada texto extraído
    for (const texto of todosLosTextos) {
      // Detectar campos importantes
      const esImportante = (
        texto.toLowerCase().includes('unidades') ||
