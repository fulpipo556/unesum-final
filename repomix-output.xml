    // ========== EXTRACCIÓN ESPECÍFICA PARA LA SECCIÓN DE VISADO ==========
    console.log('\n=== EXTRAYENDO SECCIÓN DE VISADO ===\n');
    
    // Buscar el índice donde empieza VISADO en el texto
    const visadoIndex = text.search(/(\d+\.?\s*)?VISADO/i);
    
    if (visadoIndex !== -1) {
