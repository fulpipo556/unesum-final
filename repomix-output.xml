                            title="Ver"
                          >
                            <Eye className="h-4 w-4" />
                          </Button>
                          <Button
                            variant="outline"
                            size="sm"
                            className="text-emerald-600 border-emerald-300 hover:bg-emerald-50"
                            onClick={() => router.push(`/dashboard/admin/programa-analitico/editar/${programa.id}`)}
                            title="Editar"
